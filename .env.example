# Server
PORT=3100
HOST=0.0.0.0

# Enabled services (comma-separated): default single-service mode for mindplus.
# To re-enable multi-service mode, set: ENABLED_SERVICES=mindplus,asloga
ENABLED_SERVICES=mindplus

# Security
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRY=7d

# Database (MySQL only)
# DB_CLIENT 仅支持：`mysql`
DB_CLIENT=mysql
# MySQL 连接串示例：
# DATABASE_URL=mysql://user:password@127.0.0.1:3306/minduser?charset=utf8mb4
DATABASE_URL=
# MySQL 连接池大小（仅 mysql 生效）
DB_POOL_SIZE=10

# CORS
CORS_ORIGIN=*

# Optional: internal key for recharge callback API
# If empty, recharge open API does not check x-internal-key header
INTERNAL_RECHARGE_KEY=

# Email verification for registration
# Set to 1 to enable email code flow.
EMAIL_VERIFICATION_ENABLED=0
EMAIL_CODE_TTL_SECONDS=600
EMAIL_CODE_RESEND_SECONDS=60
# Optional: custom secret for hashing email code
EMAIL_CODE_SECRET=

# SMTP settings (required when EMAIL_VERIFICATION_ENABLED=1)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=1
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_REPLY_TO=

# Optional: external cardkey / legacy record path overrides
# If empty, server will auto-probe default paths:
# mindplus -> ~/LINGINE/minduser/cardkey
# asloga   -> ~/LINGINE/mindvideo/* (fallback ~/LINGINE/mindviedo/*)
MINDPLUS_CARDKEY_DIR=
ASLOGA_CARDKEY_DIR=
MINDPLUS_CREDITS_RECORD_FILE=
ASLOGA_CREDITS_RECORD_FILE=

# Feature home URLs (used when login has no redirect parameter)
MINDPLUS_FEATURE_HOME_URL=http://127.0.0.1:8080/slide/
ASLOGA_FEATURE_HOME_URL=

# Seeded admin accounts (per service)
MINDPLUS_ADMIN_USERNAME=admin
MINDPLUS_ADMIN_PASSWORD=Admin@123
ASLOGA_ADMIN_USERNAME=admin
ASLOGA_ADMIN_PASSWORD=Admin@123
